# ─── LLM — xAI ───────────────────────────────────────────────────────────────
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# ─── LLM — OpenAI (remove if not using) ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: override per-tier model for OpenAI (defaults to o3-mini / gpt-4o-mini / gpt-4o)
# OPENAI_REASONING_MODEL=o3-mini
# OPENAI_FAST_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o

# ─── LLM — Anthropic (remove if not using) ───────────────────────────────────
ANTHROPIC_API_KEY=
# Optional: override per-tier model for Anthropic (defaults to claude-opus-4-7 / claude-haiku-4-5-20251001 / claude-opus-4-7)
# ANTHROPIC_REASONING_MODEL=claude-opus-4-7
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_VISION_MODEL=claude-opus-4-7

# ─── LLM — Ollama (local, no key required) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Optional: override per-tier model for Ollama (defaults to llama3.3 / llama3.2 / llava)
# OLLAMA_REASONING_MODEL=llama3.3
# OLLAMA_FAST_MODEL=llama3.2
# OLLAMA_VISION_MODEL=llava

# ─── LLM — Azure OpenAI (remove if not using) ────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# Default deployment used when tier-specific deployments are not set
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Optional: override per-tier deployment (falls back to AZURE_OPENAI_DEPLOYMENT)
# AZURE_OPENAI_REASONING_DEPLOYMENT=o3-mini
# AZURE_OPENAI_FAST_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# ─── LLM Routing ─────────────────────────────────────────────────────────────
# Model used for orchestration / complex reasoning calls (xAI default; override per provider above)
LLM_REASONING_MODEL=grok-3-mini
# Model used for wizard / fast completions (xAI default; override per provider above)
LLM_FAST_MODEL=grok-3-fast
# Model used for vision calls (xAI default; override per provider above)
LLM_VISION_MODEL=grok-2-vision

# ─── LLM Resilience ──────────────────────────────────────────────────────────
# Request timeout in milliseconds (default: 30000)
LLM_DEFAULT_TIMEOUT_MS=30000
# Maximum retries on transient failures (service errors, rate limits)
LLM_MAX_RETRIES=2
