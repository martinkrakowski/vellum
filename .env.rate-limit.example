# Rate Limiting — @generated by @hexagen/sync
# Merge these into your .env.local

# Requests per minute per session (tune to match your LLM provider tier)
TEXT_RPM=40
IMAGE_RPM=12
GENERAL_RPM=60

# Warn at this fraction of the limit (0.0–1.0). 0.8 = warn at 80 %
RATE_LIMIT_WARN_AT=0.8

# Session cookie TTL in seconds (604800 = 7 days)
RATE_LIMIT_SESSION_TTL=604800

# Set to "true" during local development to see per-request limit proximity logs
RATE_LIMIT_DEBUG=false

# Set to "true" ONLY when a trusted reverse proxy unconditionally overwrites
# X-Forwarded-For (e.g. Nginx, Cloudflare, AWS ALB). Leaving this false means
# socket.remoteAddress is used, which prevents header-spoofing bypasses.
RATE_LIMIT_TRUST_PROXY=false
