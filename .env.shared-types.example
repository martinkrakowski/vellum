# ─── Session cookie ───────────────────────────────────────────────────────────
# Used by session-manager.ts's cookie helpers. AUTH_COOKIE_NAME overrides the
# install-time default; AUTH_SESSION_MAX_AGE is in seconds (7d = 604800).
AUTH_COOKIE_NAME=__auth_session
AUTH_SESSION_MAX_AGE=604800

# ─── Mock user (used by auth-mock middleware + getCurrentUser short-circuits) ─
# These override the static defaults in src/infrastructure/auth/mock-user.ts.
# Leave them unset to use the defaults ("Demo User" / "demo@example.com" / etc.).
MOCK_USER_ID=
MOCK_USER_NAME=
MOCK_USER_EMAIL=
MOCK_USER_ROLES=
MOCK_USER_AVATAR_URL=
