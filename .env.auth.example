# ─── Authentication mode ───────────────────────────────────────────────────────
# AUTH_MODE=mock makes the dev middleware short-circuit every request as
# MOCK_USER (defined in shared-types). Any other value (or unset) lets a real
# provider's middleware (google-oauth, supabase-auth, etc.) take over.
AUTH_MODE=mock

# ─── Shared cookie + mock-user overrides ──────────────────────────────────────
# AUTH_COOKIE_NAME / AUTH_SESSION_MAX_AGE / MOCK_USER_* are configured in
# shared-types' .env block. Add them to .env.local from there.
