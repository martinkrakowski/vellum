# Supabase — copy these into .env.local
# Project URL + anon key: Project Settings → API (both are public/client-safe)
NEXT_PUBLIC_SUPABASE_URL=https://piuuvbewgjtipilfpcjh.supabase.co/rest/v1/
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Vc7CNt7pd4ryCKqktHXK0g_sARJfnuo

# Service role key: Project Settings → API. SERVER-ONLY — never expose to the
# browser. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Storage
# Buckets to create: uploads
SUPABASE_SIGNED_URL_EXPIRY=3600

# Drizzle (only when orm is enabled): Project Settings → Database → Connection string
# SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
