# ─── BullMQ / Redis ───────────────────────────────────────────────────────────
# Redis connection string. Leave unset (and use BULLMQ_FALLBACK_MODE=auto)
# to run the queue layer in in-process fallback mode during local dev.
REDIS_URL=redis://localhost:6379

# Connection retry behaviour.
REDIS_MAX_RETRIES=3
REDIS_CONNECTION_TIMEOUT_MS=5000

# auto   — try Redis, fall back to in-process executor if it errors
# always — force in-process (never connect)
# never  — fail loudly when Redis is unavailable
BULLMQ_FALLBACK_MODE=auto

# Comma-separated queue names. Overrides the install-time default.
BULLMQ_QUEUE_NAMES=default,images,notifications

# Default per-queue worker concurrency.
WORKER_CONCURRENCY=2

# Outbound webhook fetch timeout (ms). Caps how long a single attempt waits
# for the target to respond before aborting; BullMQ then retries per the
# queue's policy. Only relevant if you installed the webhook example.
WEBHOOK_FETCH_TIMEOUT_MS=30000

# ─── Bull Board dashboard ─────────────────────────────────────────────────────
# Set BULL_BOARD_ENABLED=false to hide the dashboard entirely.
BULL_BOARD_ENABLED=true
BULL_BOARD_BASE_PATH=/admin/queues

# Required in production — Basic Auth credentials. Leave blank in dev to
# expose the dashboard without auth.
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=
