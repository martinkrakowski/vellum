# -------- Observability (logging) --------
# All optional — the logger ships sensible defaults.
# error | warn | info | debug
LOG_LEVEL=info
# json | pretty-dev | auto (auto = pretty in dev, json in production)
LOG_FORMAT=auto
# Header carrying the per-request correlation id
CORRELATION_ID_HEADER=x-request-id
#
# Note: redaction masks by field name only. Error messages and stack traces are
# logged verbatim (they can contain file paths) — keep secrets out of error
# messages and treat your logs as sensitive at rest.
